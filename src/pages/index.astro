        height={802}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-numbers" aria-hidden="true">
      <span class="hero-247">247</span>
    </div>
