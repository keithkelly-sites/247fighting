    </div>
  </section>

  <!-- ===== PODCAST ===== -->
  <section class="podcast section">
    <div class="container">
      <div class="podcast-grid">
        <div class="podcast-visual reveal">
          <div class="podcast-mosaic">
            <Image src={podcastMattImg} alt="Pittsburgh Combat Sports Podcast with Matt Leyshock" width={1024} height={576} loading="lazy" class="mosaic-main" />
            <Image src={podcastDjImg} alt="DJ Cake on Pittsburgh Combat Sports Podcast" width={1024} height={576} loading="lazy" class="mosaic-secondary" />
          </div>
        </div>
        <div class="podcast-text reveal reveal-delay-1">
          <span class="section-label">Listen</span>
          <h2 class="podcast-heading">Pittsburgh Combat Sports Podcast</h2>
          <p>Fight breakdowns, fighter interviews, event previews, and everything happening in Pittsburgh combat sports. Hosted by the 247 FC crew.</p>
          <a href="https://www.stream247live.com/categories/pittsburgh-combat-sports-podcast-watch-listen-247-fighting-championships" target="_blank" rel="noopener noreferrer" class="btn btn--outline">Listen Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== COMPETE ===== -->
  <section class="compete section" id="compete">
    <div class="container">
      <div class="compete-inner reveal">
        <span class="section-label">Step Into the Cage</span>
        <h2 class="compete-heading">Want to Fight?</h2>
        <p class="compete-lead">Whether you train MMA, Muay Thai, grappling, or wrestling, we want to hear from you. Fill out a registration form and take the first step toward fighting on the 247 FC stage.</p>
        <div class="compete-grid">
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSeQOIjqtMDBljZcQKN4vgU-SDSB3Uv716hIe_AXR9gJ7ERS5Q/viewform" target="_blank" rel="noopener noreferrer" class="compete-card">
            <span class="compete-discipline">MMA</span>
            <span class="compete-arrow">&rarr;</span>
          </a>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSeLnk17JawcU7b50eZRHldKPySspQ8GlM54ShsMJlwHwZElgg/viewform" target="_blank" rel="noopener noreferrer" class="compete-card">
            <span class="compete-discipline">Grappling</span>
            <span class="compete-arrow">&rarr;</span>
          </a>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSfoiPDMGJwUyLIXWxPntnWLvSmZ6Y3MJcCCf7b-581icCfu4A/viewform" target="_blank" rel="noopener noreferrer" class="compete-card">
            <span class="compete-discipline">Muay Thai</span>
            <span class="compete-arrow">&rarr;</span>
          </a>
          <a href="https://docs.google.com/forms/d/e/1FAIpQLSeXso4ufkPshq4ZF696MVvhiUhmatiA9cL7YesLgZPuW8-h-g/viewform" target="_blank" rel="noopener noreferrer" class="compete-card">
            <span class="compete-discipline">Wrestling</span>
