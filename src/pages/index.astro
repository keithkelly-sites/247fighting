      </div>
    </div>
  </section>

  <!-- ===== SPONSORS ===== -->
  <section class="sponsors section">
    <div class="container">
      <div class="reveal">
        <span class="section-label">Our Partners</span>
        <h2 class="sponsors-heading">Sponsors</h2>
      </div>
      <div class="sponsors-grid reveal reveal-delay-1">
        <a href="https://sunnydaysinhomecare.com/" target="_blank" rel="noopener noreferrer" class="sponsor-item" aria-label="Sunny Days In-Home Care">
          <Image src={sponsorSunnyImg} alt="Sunny Days In-Home Care" width={200} height={111} loading="lazy" />
        </a>
        <a href="https://www.instagram.com/stripdistrictmeats/" target="_blank" rel="noopener noreferrer" class="sponsor-item" aria-label="Strip District Meats">
          <Image src={sponsorMeatsImg} alt="Strip District Meats" width={120} height={120} loading="lazy" />
        </a>
        <a href="https://gogreenwindowspgh.com/" target="_blank" rel="noopener noreferrer" class="sponsor-item" aria-label="Go Green Windows">
          <Image src={sponsorGreenImg} alt="Go Green Windows" width={200} height={93} loading="lazy" />
        </a>
        <a href="https://www.247homeremodeling.com/" target="_blank" rel="noopener noreferrer" class="sponsor-item" aria-label="247 Home Remodeling">
          <Image src={sponsor247Img} alt="247 Home Remodeling" width={200} height={67} loading="lazy" />
        </a>
        <a href="http://therehabcentres.com/" target="_blank" rel="noopener noreferrer" class="sponsor-item" aria-label="The Rehab Centre">
          <Image src={sponsorRehabImg} alt="The Rehab Centre" width={200} height={59} loading="lazy" />
        </a>
        <span class="sponsor-item" aria-label="Pellman">
          <Image src={sponsorPellmanImg} alt="Pellman" width={200} height={100} loading="lazy" />
        </span>
