    </div>
  </section>

  <!-- ===== CONTACT CTA ===== -->
  <section class="cta-section section">
    <div class="container">
      <div class="cta-inner reveal">
        <h2 class="cta-heading">Let's Make Something Happen</h2>
        <p>Fan, coach, gym owner, sponsor. We build partnerships. Got something in mind?</p>
        <a href="/contact/" class="btn btn--primary">Contact Us</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Parallax on hero 247 text
  const hero247 = document.querySelector('.hero-247') as HTMLElement | null;
  const heroSection = document.getElementById('hero');
  if (hero247 && heroSection) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      const heroH = heroSection.offsetHeight;
      if (y < heroH) {
        const progress = y / heroH;
        hero247.style.transform = `translateY(${y * 0.3}px) scale(${1 + progress * 0.1})`;
        hero247.style.opacity = String(Math.max(0, 1 - progress * 1.2));
      }
    }, { passive: true });
  }

  // Continuous scroll animation for action strip
  const track = document.getElementById('strip-track') as HTMLElement | null;
  if (track) {
    let pos = 0;
    const speed = 0.5;
    let running = true;

    function animate() {
      if (!running || !track) return;
      pos += speed;
      const halfWidth = track.scrollWidth / 2;
      if (pos >= halfWidth) pos = 0;
      track.style.transform = `translateX(-${pos}px)`;
      requestAnimationFrame(animate);
    }

    requestAnimationFrame(animate);

    const stripSection = track.closest('.action-strip');
    if (stripSection) {
      stripSection.addEventListener('mouseenter', () => { running = false; });
      stripSection.addEventListener('mouseleave', () => { running = true; requestAnimationFrame(animate); });
    }
  }
</script>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--black-pure);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.55;
    filter: contrast(1.1) brightness(0.85);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(to top, var(--black-pure) 0%, transparent 50%),
      linear-gradient(to right, oklch(0.08 0.005 75 / 0.6) 0%, transparent 60%);
  }

  .hero-numbers {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    pointer-events: none;
  }

  .hero-247 {
    font-family: var(--font-display), sans-serif;
    font-size: var(--text-mega);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 2px var(--gold-bright);
    line-height: 0.85;
    letter-spacing: -0.03em;
    opacity: 0.6;
    mix-blend-mode: screen;
    user-select: none;
    will-change: transform, opacity;
    text-shadow: 0 0 80px oklch(0.82 0.16 85 / 0.15);
  }

  @media (min-width: 768px) {
    .hero-247 {
      -webkit-text-stroke: 3px var(--gold-bright);
    }
  }

  .hero-content {
    position: relative;
    z-index: 4;
    padding-bottom: clamp(3rem, 2rem + 4vw, 6rem);
    width: 100%;
  }

  .hero-location {
    font-family: var(--font-accent), sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold-bright);
    margin-bottom: var(--space-sm);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-location::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1px;
    background: var(--gold-bright);
  }

  .hero-heading {
    font-size: var(--text-4xl);
    line-height: 0.95;
    margin-bottom: var(--space-sm);
  }

  .hero-line-1 { display: block; }

  .hero-line-2 {
    display: block;
    color: var(--gold-bright);
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--white-dim);
    max-width: 42ch;
    margin-bottom: var(--space-md);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-scroll-cue {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
  }

  .hero-scroll-cue span {
    display: block;
    width: 1.5px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold-bright), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0; transform: scaleY(0.5); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* ===== NEXT EVENT ===== */
  .next-event {
    background: var(--dark);
    border-top: 1px solid var(--dark-border);
    border-bottom: 1px solid var(--dark-border);
  }

  .event-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: center;
  }

  @media (min-width: 900px) {
    .event-grid {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .event-image {
    position: relative;
    overflow: hidden;
  }

  .event-image img {
    width: 100%;
    height: auto;
    display: block;
    filter: contrast(1.05);
  }

  .event-badge {
    position: absolute;
