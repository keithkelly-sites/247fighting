          <h2 class="event-title">247 MMA at the Venue 5</h2>
          <p class="event-date">Saturday, March 14</p>
          <p class="event-venue">Sunny Days Arena &middot; North Versailles, PA</p>
          <div class="event-schedule">
            <div class="schedule-item">
              <span class="schedule-time">5:00 PM</span>
              <span class="schedule-label">Doors Open</span>
            </div>
            <div class="schedule-item">
              <span class="schedule-time">6:00 PM</span>
              <span class="schedule-label">Grappling</span>
            </div>
            <div class="schedule-item">
