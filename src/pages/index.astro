---
/*
  DESIGN CONCEPT — "The Arena Starts Here"

  Inspired by Matchroom Boxing's fluid clamp() typography and high-contrast dark/light system,
  UFC.com's fighter-photography-dominant layout, and the 2025-2026 trend of typography-as-architecture
  with scroll-driven reveals.

  The concept: the site IS the fight night experience. You open the page and you're staring at
  a darkened arena — the aerial crowd shot from Brawl in the Burgh 23 — with "247" so massive
  it becomes the architecture of the space. The gold is a spotlight cutting through darkness.
  Every section transition feels like moving deeper into the venue.

  Signature moment: The hero where "247" fills the viewport at 20vw+, outlined in gold,
  with the crowd photo composited behind through mix-blend-mode. The text IS the arena.

  Reference sites: Matchroom Boxing (Awwwards), UFC.com, modern dark parallax sports sites.
*/
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

// Image imports
import heroImg from '../assets/images/tatzuo-photo-bitb23-full-crowd-above-copy-resize-1920w.jpg';
import eventBannerImg from '../assets/images/bitb30-20--20event-20banner-20main-1920w.jpg';
import beltImg from '../assets/images/angel-247-fighting-championships-belt-for-website-medium-1920w.jpg';
import faceoffImg from '../assets/images/justin-patton-face-247-fighting-championships-400x305-1920w.jpg';
import flyingKneeImg from '../assets/images/lucas-seibert-flying-knee-bitb20-247-fighting-championships-medium-1920w.jpg';
import winnerImg from '../assets/images/20231020-ag4i5553-scaled-600x400-1920w.jpg';
import interviewImg from '../assets/images/20231021-ag4i2717-scaled-600x400-1920w.jpg';
import crowdTablesImg from '../assets/images/20231216-ag4i4881-scaled-600x400-1920w.jpg';
import venueSignImg from '../assets/images/sunny-days-arena-sign-close-up-1920w.jpg';
import fightPosterImg from '../assets/images/247-20mma-20--20ig-20poster-204-1920w.jpg';
import podcastMattImg from '../assets/images/matt-leyshock-247-fighting-championships-combat-sports-podcast-full-thumbnail-large-1920w.jpg';
import podcastDjImg from '../assets/images/dj-cake-247-fighting-championships-pittsburgh-podcast-large-1920w.jpg';
import sponsorSunnyImg from '../assets/images/sunny-400x222-1920w.jpg';
import sponsorMeatsImg from '../assets/images/stip-district-meats-circle-logo-small-1920w.jpg';
import sponsorGreenImg from '../assets/images/go-green-yard-sign-400x185-1920w.jpg';
import sponsor247Img from '../assets/images/247_logo-1_gold-1920w.jpg';
import sponsorRehabImg from '../assets/images/rehab-centre-logo-400x117-1920w.jpg';
import sponsorPellmanImg from '../assets/images/pellman-logo-1920w.jpg';

const businessJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: '247 Fighting Championships',
  url: 'https://247fighting.keithkelly.dev',
  telephone: '412-212-6444',
  email: 'info@247entgroup.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1701 Lincoln Highway, Suite 247',
    addressLocality: 'North Versailles',
    addressRegion: 'PA',
    postalCode: '15137',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.3711352,
    longitude: -79.7856762,
  },
  image: 'https://247fighting.keithkelly.dev/images/tatzuo-photo-bitb23-full-crowd-above-copy-resize-1920w.jpg',
  description: 'Pittsburgh\'s home for live MMA, Muay Thai, and grappling events at Sunny Days Arena in North Versailles, PA.',
  sameAs: [
    'https://www.facebook.com/247fighting',
    'https://www.instagram.com/247fightingchampionships/',
    'https://www.youtube.com/@247FightingChampionships',
    'https://twitter.com/247fighting',
    'https://www.tiktok.com/@247fighting',
  ],
};

const actionImages = [
  { src: beltImg, alt: 'Fighter holding championship belt in front of crowd' },
  { src: faceoffImg, alt: 'Two fighters face off during an MMA bout' },
  { src: flyingKneeImg, alt: 'Fighter lands a flying knee in the cage' },
  { src: winnerImg, alt: 'Winner announced with hand raised in the cage' },
  { src: interviewImg, alt: 'Post-fight interview inside the cage' },
  { src: crowdTablesImg, alt: 'Crowd watching fights at ringside tables' },
];
---

<Layout title="247 Fighting Championships | Pittsburgh's Home for Live MMA" jsonLd={businessJsonLd}>

  {/* JSON-LD structured data: application/ld+json passed via Layout jsonLd prop */}

  <!-- ===== HERO ===== -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <Image
        src={heroImg}
        alt="Packed crowd at a 247 Fighting Championships event inside Sunny Days Arena"
