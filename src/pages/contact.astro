---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | 247 Fighting Championships" description="Got questions, want to sponsor, or ready to fight? Reach out to 247 Fighting Championships in North Versailles, PA.">

  <section class="contact-hero">
    <div class="container">
      <span class="section-label">Get in Touch</span>
      <h1 class="contact-title">Let's Talk<br />Fight Night</h1>
      <p class="contact-subtitle">Fans, fighters, coaches, gym owners, sponsors. We're here for all of you.</p>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <section class="contact-content section">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-form-wrap reveal">
          <h2 class="form-heading">Send a Message</h2>
          <form class="contact-form" action="https://api.keithkelly.dev/contact/247fighting" method="POST" name="contact">
            <div class="form-row">
              <div class="form-field">
                <label for="first-name">First Name</label>
                <input type="text" id="first-name" name="first_name" required autocomplete="given-name" />
              </div>
              <div class="form-field">
                <label for="last-name">Last Name</label>
                <input type="text" id="last-name" name="last_name" required autocomplete="family-name" />
              </div>
            </div>
            <div class="form-field">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
            <div class="form-field">
              <label for="message">Comment or Message</label>
              <textarea id="message" name="message" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn--primary form-submit">Send Message</button>
          </form>
        </div>

        <div class="contact-info-col">
          <div class="info-card">
            <h3>Location</h3>
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=1701+Lincoln+Highway+Suite+247+North+Versailles+PA"
              target="_blank"
              rel="noopener noreferrer"
              class="map-link"
            >
              <div class="map-container">
                <img src="/images/location-map.svg" alt="Map showing 247 Fighting Championships location near Lincoln Highway in North Versailles, PA" width="600" height="400" loading="lazy" />
              </div>
              <div class="map-bar">
                <div>
                  <strong>Sunny Days Arena</strong>
                  <span>1701 Lincoln Highway, Ste 247</span>
                  <span>North Versailles, PA</span>
                </div>
                <span class="map-cta">Open in Maps &nearr;</span>
              </div>
            </a>
          </div>

          <div class="info-card">
            <h3>Reach Us</h3>
            <div class="info-items">
              <a href="tel:+14122126444" class="info-item">
                <span class="info-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                </span>
                <span>412-212-6444</span>
              </a>
              <a href="mailto:info@247entgroup.com" class="info-item">
                <span class="info-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </span>
                <span>info@247entgroup.com</span>
              </a>
            </div>
          </div>

          <div class="info-card">
            <h3>Want to Fight?</h3>
            <p class="compete-text">Ready to step into the cage? Fill out a registration form and join the 247 FC family.</p>
            <div class="compete-links">
              <a href="https://docs.google.com/forms/d/e/1FAIpQLSeQOIjqtMDBljZcQKN4vgU-SDSB3Uv716hIe_AXR9gJ7ERS5Q/viewform" target="_blank" rel="noopener noreferrer" class="compete-link">MMA</a>
              <a href="https://docs.google.com/forms/d/e/1FAIpQLSeLnk17JawcU7b50eZRHldKPySspQ8GlM54ShsMJlwHwZElgg/viewform" target="_blank" rel="noopener noreferrer" class="compete-link">Grappling</a>
              <a href="https://docs.google.com/forms/d/e/1FAIpQLSfoiPDMGJwUyLIXWxPntnWLvSmZ6Y3MJcCCf7b-581icCfu4A/viewform" target="_blank" rel="noopener noreferrer" class="compete-link">Muay Thai</a>
              <a href="https://docs.google.com/forms/d/e/1FAIpQLSeXso4ufkPshq4ZF696MVvhiUhmatiA9cL7YesLgZPuW8-h-g/viewform" target="_blank" rel="noopener noreferrer" class="compete-link">Wrestling</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== CONTACT HERO ===== */
  .contact-hero {
    position: relative;
    padding: calc(var(--space-xl) + 2rem) 0 var(--space-lg);
    overflow: hidden;
  }

  .contact-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-xs);
  }

  .contact-subtitle {
    font-size: var(--text-lg);
    color: var(--white-muted);
    max-width: 45ch;
  }

  .hero-glow {
    position: absolute;
    top: -40%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, oklch(0.82 0.16 85 / 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ===== GRID ===== */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-md);
    }
  }

  /* ===== FORM ===== */
  .form-heading {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-field {
    margin-bottom: 1.25rem;
  }

  .form-field label {
    display: block;
    font-family: var(--font-accent), sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white-dim);
    margin-bottom: 0.5rem;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    padding: 0.85rem 1rem;
    background: var(--dark-card);
    border: 1.5px solid var(--dark-border);
    color: var(--white);
    font-family: var(--font-body), sans-serif;
    font-size: var(--text-base);
    transition: border-color var(--duration-fast);
    border-radius: 0;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--gold-bright);
  }

  .form-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-submit {
    margin-top: 0.5rem;
    width: 100%;
  }

  @media (min-width: 600px) {
    .form-submit {
      width: auto;
    }
  }

  /* ===== INFO CARDS ===== */
  .contact-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: var(--dark-card);
    border: 1px solid var(--dark-border);
    padding: 1.5rem;
  }

  .info-card h3 {
    font-family: var(--font-accent), sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold-bright);
    margin-bottom: 1rem;
  }

  /* Map */
  .map-link {
    display: block;
    overflow: hidden;
    border: 1px solid var(--dark-border);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .map-link:hover {
    transform: scale(1.01);
  }

  .map-container {
    overflow: hidden;
  }

  .map-container img {
    width: 100%;
    height: auto;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .map-link:hover .map-container img {
    transform: scale(1.03);
  }

  .map-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1rem;
    background: var(--dark);
    gap: 1rem;
  }

  .map-bar strong {
    display: block;
    font-family: var(--font-display), sans-serif;
    font-size: var(--text-sm);
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .map-bar span {
    display: block;
    font-size: var(--text-xs);
    color: var(--white-muted);
  }

  .map-cta {
    font-family: var(--font-accent), sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gold-bright) !important;
    white-space: nowrap;
  }

  /* Info items */
  .info-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--white-dim);
    font-size: var(--text-base);
    transition: color var(--duration-fast);
  }

  .info-item:hover {
    color: var(--gold-bright);
  }

  .info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: oklch(1 0 0 / 0.04);
    border-radius: 50%;
    flex-shrink: 0;
    color: var(--gold-bright);
  }

  /* Compete links */
  .compete-text {
    font-size: var(--text-sm);
    color: var(--white-muted);
    margin-bottom: 1rem;
  }

  .compete-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .compete-link {
    display: inline-block;
    padding: 0.5em 1.2em;
    font-family: var(--font-accent), sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1.5px solid var(--dark-border);
    color: var(--white-dim);
    transition: all var(--duration-fast);
  }

  .compete-link:hover {
    border-color: var(--gold-bright);
    color: var(--gold-bright);
    background: oklch(0.82 0.16 85 / 0.05);
  }
</style>
