---
import { Font, Image } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import logoImg from '../assets/images/logo-copy-1920w.jpg';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Pittsburgh\'s home for live MMA, Muay Thai, and grappling. Get tickets, stream fights, and experience 247 Fighting Championships at Sunny Days Arena in North Versailles, PA.',
  ogImage = '/images/tatzuo-photo-bitb23-full-crowd-above-copy-resize-1920w.jpg',
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Tickets', href: 'https://www.tixr.com/groups/sunnydaysarena/', external: true },
  { label: 'Live Stream', href: 'https://www.stream247live.com/', external: true },
  { label: 'Podcast', href: 'https://www.stream247live.com/categories/pittsburgh-combat-sports-podcast-watch-listen-247-fighting-championships', external: true },
  { label: 'Contact', href: '/contact/' },
];

const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/images/favicon-48.png" />
    <link rel="alternate icon" href="/images/favicon.ico" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="247 Fighting Championships" />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-accent" preload />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a href="/" class="logo" aria-label="247 Fighting Championships home">
          <Image src={logoImg} alt="247 Fighting Championships" width={50} height={47} />
        </a>

        <nav class="main-nav" id="main-nav" aria-label="Main navigation">
          <ul class="nav-list">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class:list={['nav-link', { 'is-active': !link.external && currentPath === link.href }]}
                  {...(!link.external && currentPath === link.href ? { 'aria-current': 'page' } : {})}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                  {link.external && <span class="external-icon" aria-hidden="true">&nearr;</span>}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <a href="https://www.tixr.com/groups/sunnydaysarena/" target="_blank" rel="noopener noreferrer" class="btn btn--primary header-cta">
          Get Tickets
        </a>

        <button class="menu-toggle" id="menu-toggle" aria-expanded="false" aria-controls="main-nav" aria-label="Toggle menu">
          <span class="menu-bar"></span>
          <span class="menu-bar"></span>
          <span class="menu-bar"></span>
        </button>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-top">
          <div class="footer-brand">
            <Image src={logoImg} alt="247 Fighting Championships" width={70} height={66} class="footer-logo" />
            <p class="footer-tagline">Pittsburgh's home for live MMA and combat sports. Based in North Versailles, PA.</p>
          </div>

          <nav class="footer-links" aria-label="Footer navigation">
            <div class="footer-col">
              <h3 class="footer-heading">Events</h3>
              <ul>
                <li><a href="https://www.tixr.com/groups/sunnydaysarena/" target="_blank" rel="noopener noreferrer">Buy Tickets</a></li>
                <li><a href="https://www.stream247live.com/" target="_blank" rel="noopener noreferrer">Live Stream / PPV</a></li>
                <li><a href="https://www.sunnydaysarena.com/" target="_blank" rel="noopener noreferrer">Event Schedule</a></li>
              </ul>
            </div>

            <div class="footer-col">
              <h3 class="footer-heading">Compete</h3>
              <ul>
                <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSeQOIjqtMDBljZcQKN4vgU-SDSB3Uv716hIe_AXR9gJ7ERS5Q/viewform" target="_blank" rel="noopener noreferrer">MMA Fighter Form</a></li>
                <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSeLnk17JawcU7b50eZRHldKPySspQ8GlM54ShsMJlwHwZElgg/viewform" target="_blank" rel="noopener noreferrer">Grappler Form</a></li>
                <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSfoiPDMGJwUyLIXWxPntnWLvSmZ6Y3MJcCCf7b-581icCfu4A/viewform" target="_blank" rel="noopener noreferrer">Muay Thai Form</a></li>
                <li><a href="https://docs.google.com/forms/d/e/1FAIpQLSeXso4ufkPshq4ZF696MVvhiUhmatiA9cL7YesLgZPuW8-h-g/viewform" target="_blank" rel="noopener noreferrer">Wrestler Form</a></li>
              </ul>
            </div>

            <div class="footer-col">
              <h3 class="footer-heading">Connect</h3>
              <ul>
                <li><a href="/contact/">Contact Us</a></li>
                <li><a href="https://www.stream247live.com/categories/pittsburgh-combat-sports-podcast-watch-listen-247-fighting-championships" target="_blank" rel="noopener noreferrer">Podcast</a></li>
                <li><a href="mailto:info@247entgroup.com">info@247entgroup.com</a></li>
                <li><a href="tel:+14122126444">412-212-6444</a></li>
              </ul>
            </div>
          </nav>
        </div>

        <address class="footer-contact-address">
          247 Fighting Championships<br />
          1701 Lincoln Highway, Suite 247<br />
          North Versailles, PA 15137<br />
          <a href="tel:+14122126444">412-212-6444</a> &middot;
          <a href="mailto:info@247entgroup.com">info@247entgroup.com</a>
        </address>

        <div class="footer-socials">
          <a href="https://www.facebook.com/247fighting" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/247fightingchampionships/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.youtube.com/@247FightingChampionships" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://twitter.com/247fighting" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@247fighting" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>

        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} 247 Fighting Championships. All rights reserved.</p>
          <p class="footer-address">1701 Lincoln Highway, Suite 247, North Versailles, PA</p>
        </div>
      </div>
    </footer>

    <script>
      // Re-run on every page navigation (ClientRouter)
      document.addEventListener('astro:page-load', () => {
        // Mobile menu toggle
        const toggle = document.getElementById('menu-toggle');
        const nav = document.getElementById('main-nav');
        const header = document.getElementById('site-header');

        if (toggle && nav) {
          toggle.addEventListener('click', () => {
            const expanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', String(!expanded));
            nav.classList.toggle('is-open');
            document.body.style.overflow = expanded ? '' : 'hidden';
          });

          nav.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', () => {
              toggle.setAttribute('aria-expanded', 'false');
              nav.classList.remove('is-open');
              document.body.style.overflow = '';
            });
          });
        }

        // Header scroll state
        let lastScroll = 0;
        window.addEventListener('scroll', () => {
          const y = window.scrollY;
          if (header) {
            header.classList.toggle('is-scrolled', y > 80);
            header.classList.toggle('is-hidden', y > lastScroll && y > 400);
          }
          lastScroll = y;
        }, { passive: true });

        // Scroll reveal — use generous rootMargin so elements reveal before
        // they're fully scrolled into view, preventing "invisible content" feel
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.01, rootMargin: '0px 0px 60px 0px' });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
      });
    </script>

    <style>
      /* ===== HEADER ===== */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: oklch(0.08 0.005 75 / 0.85);
        backdrop-filter: blur(16px) saturate(1.4);
        border-bottom: 1px solid oklch(1 0 0 / 0.04);
        transition: transform var(--duration-normal) var(--ease-out),
                    background var(--duration-normal) var(--ease-out);
      }

      .site-header.is-scrolled {
        background: oklch(0.06 0.005 75 / 0.95);
        border-bottom-color: oklch(1 0 0 / 0.06);
      }

      .site-header.is-hidden {
        transform: translateY(-100%);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: var(--max-width);
        margin-inline: auto;
        padding: 0.75rem var(--content-padding);
        gap: 1.5rem;
      }

      .logo img {
        display: block;
        transition: opacity var(--duration-fast);
      }

      .logo:hover img {
        opacity: 0.8;
      }

      .nav-list {
        display: flex;
        gap: 0.25rem;
      }

      .nav-link {
        font-family: var(--font-accent), sans-serif;
        font-size: var(--text-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--white-dim);
        padding: 0.5rem 0.85rem;
        border-radius: 4px;
        transition: color var(--duration-fast), background var(--duration-fast);
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }

      .nav-link:hover,
      .nav-link.is-active {
        color: var(--white);
        background: oklch(1 0 0 / 0.06);
      }

      .nav-link.is-active {
        color: var(--gold-bright);
      }

      .external-icon {
        font-size: 0.7em;
        opacity: 0.5;
      }

      .header-cta {
        font-size: var(--text-xs);
        padding: 0.6em 1.4em;
        min-height: 40px;
      }

      /* Mobile menu */
      .menu-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        padding: 8px;
        z-index: 101;
      }

      .menu-bar {
        display: block;
        width: 24px;
        height: 2px;
        background: var(--white);
        transition: transform var(--duration-fast) var(--ease-out),
                    opacity var(--duration-fast);
      }

      @media (max-width: 900px) {
        .menu-toggle {
          display: flex;
          z-index: 200;
        }

        .header-cta {
          display: none;
        }

        .main-nav {
          position: fixed;
          top: 0;
          left: 0;
          right: 0;
          bottom: 0;
          width: 100vw;
          height: 100vh;
          height: 100dvh;
          background: #0a0a0a;
          display: flex;
          align-items: center;
          justify-content: center;
          visibility: hidden;
          opacity: 0;
          pointer-events: none;
          transition: opacity var(--duration-normal) var(--ease-out),
                      visibility 0s linear var(--duration-normal);
          z-index: 150;
        }

        .main-nav.is-open {
          visibility: visible;
          opacity: 1;
          pointer-events: auto;
          transition: opacity var(--duration-normal) var(--ease-out),
                      visibility 0s linear 0s;
        }

        .main-nav .nav-list {
          flex-direction: column;
          align-items: center;
          gap: 0.75rem;
        }

        .main-nav .nav-link {
          font-size: var(--text-xl);
          padding: 0.75rem 1.5rem;
          color: var(--white);
        }

        .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(1) {
          transform: translateY(7px) rotate(45deg);
        }
        .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(2) {
          opacity: 0;
        }
        .menu-toggle[aria-expanded="true"] .menu-bar:nth-child(3) {
          transform: translateY(-7px) rotate(-45deg);
        }
      }

      /* ===== FOOTER ===== */
      .site-footer {
        background: var(--dark);
        border-top: 1px solid var(--dark-border);
        padding-block: var(--space-lg) var(--space-md);
      }

      .footer-top {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-lg);
        padding-bottom: var(--space-md);
        border-bottom: 1px solid var(--dark-border);
      }

      @media (min-width: 768px) {
        .footer-top {
          grid-template-columns: 1.2fr 2fr;
        }
      }

      .footer-logo {
        margin-bottom: 1rem;
      }

      .footer-tagline {
        font-size: var(--text-sm);
        color: var(--white-muted);
        max-width: 30ch;
      }

      .footer-links {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: var(--space-md);
      }

      .footer-heading {
        font-family: var(--font-accent), sans-serif;
        font-size: var(--text-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--gold-bright);
        margin-bottom: 1rem;
      }

      .footer-col ul {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .footer-col a {
        font-size: var(--text-sm);
        color: var(--white-muted);
        transition: color var(--duration-fast);
      }

      .footer-col a:hover {
        color: var(--white);
      }

      .footer-socials {
        display: flex;
        gap: 1rem;
        padding-block: var(--space-md);
      }

      .footer-socials a {
        color: var(--white-muted);
        transition: color var(--duration-fast), transform var(--duration-fast);
      }

      .footer-socials a:hover {
        color: var(--gold-bright);
        transform: translateY(-2px);
      }

      .footer-bottom {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 2rem;
      }

      .footer-bottom p {
        font-size: var(--text-xs);
        color: var(--white-muted);
      }

      .footer-address {
        opacity: 0.6;
      }

      /* Skip to content */
      .skip-to-content {
        position: fixed;
        top: -100%;
        left: 1rem;
        z-index: 9999;
        padding: 0.75rem 1.5rem;
        background: var(--gold-bright);
        color: var(--black-pure);
        font-family: var(--font-accent), sans-serif;
        font-size: var(--text-sm);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: top var(--duration-fast) var(--ease-out);
      }

      .skip-to-content:focus {
        top: 1rem;
      }

      /* Footer address */
      .footer-contact-address {
        font-style: normal;
        font-size: var(--text-xs);
        color: var(--white-muted);
        line-height: 1.8;
        padding-block: var(--space-sm);
        border-bottom: 1px solid var(--dark-border);
      }

      .footer-contact-address a {
        color: var(--white-dim);
        transition: color var(--duration-fast);
      }

      .footer-contact-address a:hover {
        color: var(--gold-bright);
      }
    </style>
  </body>
</html>
